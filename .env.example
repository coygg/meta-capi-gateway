APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8080
APP_SECRET=change-me-to-a-long-random-string
DB_PATH=storage/gateway.sqlite

# Required only for Docker Compose HTTPS self-hosting.
GATEWAY_DOMAIN=

# Optional. If blank, the portal shows the APP_BASE_URL host as the CNAME target.
# In production this is usually your canonical gateway host, for example gateway.yourdomain.com.
GATEWAY_CNAME_TARGET=

# Set true in production behind HTTPS.
COOKIE_SECURE=false
TRUST_PROXY=false
