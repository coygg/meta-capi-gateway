APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8080
APP_SECRET=change-me-to-a-long-random-string
DB_PATH=storage/gateway.sqlite

# Optional. If blank, the portal shows the APP_BASE_URL host as the CNAME target.
# In production this is usually your canonical gateway host, for example gateway.yourdomain.com.
GATEWAY_CNAME_TARGET=

# Set true in production behind HTTPS.
COOKIE_SECURE=false
TRUST_PROXY=false

# CAPI defaults to dry run so local tests cannot leak data to Meta.
CAPI_DRY_RUN=true
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v20.0
META_GRAPH_BASE_URL=https://graph.facebook.com
META_HTTP_TRANSPORT=auto
META_TEST_EVENT_CODE=

# Required for POST /capi/intake-completed.
INTAKE_WEBHOOK_SECRET=change-me-webhook-secret
